{
  "name": "mail-tauri",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tauri build",
    "build:web": "tsc -b && vite build",
    "build:linux": "tauri build --bundles deb,rpm",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:macos": "tauri build",
    "check": "pnpm build:web && cargo check --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lucide-react": "^0.468.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1"
  }
}
